    {
      "id": 56,
      "title": "GPU ハードウェア健全性",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 105
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "color-text"
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "^(Time|device|devicetype|pci_bus_id|__name__|instance|job|address|cluster|Hostname|env|hostname|location|product|productline|role)$"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          },
