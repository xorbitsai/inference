    {
      "id": 8,
      "title": "Model Deployment Overview",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 114
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "text": "Failed"
                      },
                      "1": {
                        "color": "green",
                        "text": "Running"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "custom.width",
                "value": 90
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": []
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "expr": "xinference:model_info{cluster=~\"$cluster\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "model_name",
                "model_type",
                "model_uid",
                "replica_on_worker",
                "replica_total",
                "worker_address",
                "Value"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "model_name": 0,
              "model_type": 1,
              "model_uid": 2,
              "worker_address": 3,
              "replica_on_worker": 4,
              "replica_total": 5,
              "Value": 6
            },
            "renameByName": {
              "model_name": "Model Name",
              "model_type": "Type",
              "model_uid": "UID",
              "worker_address": "Worker",
              "replica_on_worker": "Replicas (Worker)",
              "replica_total": "Replicas (Total)",
              "Value": "Status"
            }
          }
        }
      ]
    },
