msgstr ""
"`Tutorial de asyncio de Real Python <https://realpython.com/async-io-"
"python/>`__"

#: ../../source/development/xinference_internals.rst:165
msgid ""
"`Python Official Documentation "
"<https://docs.python.org/3/library/asyncio.html>`__"
msgstr ""
