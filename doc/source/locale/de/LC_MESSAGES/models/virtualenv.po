msgid "``#llama_cpp_dependencies#``"
msgstr ""

#: ../../source/models/virtualenv.rst:342
msgid "``#diffusers_dependencies#``"
msgstr ""

#: ../../source/models/virtualenv.rst:343
msgid "``#sentence_transformers_dependencies#``"
