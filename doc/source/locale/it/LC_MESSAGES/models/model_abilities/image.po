msgid "Supported lightning version"
msgstr "Versioni Lightning supportate"

#: ../../source/models/model_abilities/image.rst:292
msgid ""
"4steps-V1.0-bf16, 4steps-V1.0, 8steps-V1.0, 8steps-V1.1-bf16, 8steps-V1.1"
msgstr ""

