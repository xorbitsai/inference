# Multi-stage build for custom PyPI server.
# Build per-architecture image containing wheels for all CUDA versions + CPU.
#
#   docker build -f Dockerfile.pypi --build-arg TARGET_ARCH=amd64 -t pypiserver:amd64 .
#   docker build -f Dockerfile.pypi --build-arg TARGET_ARCH=arm64 -t pypiserver:arm64 .
#
# Result: one image per architecture, users install with:
#   pip install torch==2.5.0+cu128 --index-url https://<pypiserver>/simple
#
# Build phases are delegated to scripts under scripts/ for faster iteration
# and cleaner layer caching:
#   download-core.sh    — common + compiled packages (no CUDA loops)
#   download-cuda.sh    — torch, cuda-ext, vllm (per CUDA version loops)
#   download-wheels.sh  — external sources (GitHub, custom indexes)

# ---- downloader stage ----
FROM python:3.12-slim AS downloader

# TARGETARCH is injected by docker buildx (amd64 / arm64).
# When not using buildx, default to amd64.
ARG TARGETARCH
ARG TARGET_ARCH=${TARGETARCH:-amd64}
ARG CUDA_VERSIONS="cu124 cu126 cu128"

# Validate TARGET_ARCH at build time
RUN case "${TARGET_ARCH}" in \
      amd64|arm64) ;; \
      *) echo "ERROR: TARGET_ARCH must be 'amd64' or 'arm64', got '${TARGET_ARCH}'" >&2; exit 1 ;; \
    esac

# Build tools needed for pure-Python sdists without wheels
# (e.g. pynini via nemo_text_processing, mecab-python3, fugashi)
RUN apt-get update && apt-get install -y --no-install-recommends \
        cmake gcc g++ make \
        libmecab-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy requirements files and scripts
COPY xinference/deploy/docker/pypi-requirements/ /build/pypi-requirements/
COPY xinference/deploy/docker/scripts/ /build/scripts/

RUN mkdir -p /data/packages

# Phase 1: Core packages — common (base + ml + models) + arch-compiled
# No CUDA loops; one pass per category.
RUN bash /build/scripts/download-core.sh ${TARGET_ARCH} /data/packages/

# Phase 2: CUDA-dependent packages — torch, cuda-ext, vllm
# Each category iterates over CUDA_VERSIONS; per-CUDA failure isolation.
RUN bash /build/scripts/download-cuda.sh ${TARGET_ARCH} "${CUDA_VERSIONS}" /data/packages/

# Phase 3: External sources — flash-attn (GitHub), xllamacpp (custom index)
RUN bash /build/scripts/download-wheels.sh ${TARGET_ARCH} "${CUDA_VERSIONS}" /data/packages/

# Clean pip cache to reduce layer size
RUN pip cache purge

# ---- final stage ----
FROM pypiserver/pypiserver:latest

COPY --from=downloader /data/packages/ /data/packages/

# Ensure correct ownership (COPY --from preserves root ownership)
RUN chown -R pypiserver:pypiserver /data/packages

EXPOSE 8080
